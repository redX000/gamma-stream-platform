# ── Core ─────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=          # console.anthropic.com → API Keys

# ── WordPress (JWT auth — NOT Application Passwords) ─────────────────────────
WORDPRESS_URL=https://gammacash.online
WORDPRESS_USERNAME=         # WP admin email
WORDPRESS_PASSWORD=         # WP admin password (same as login)

# ── Email / SMTP (Hostinger) ──────────────────────────────────────────────────
NOTIFICATION_EMAIL=         # Where weekly reports are sent
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=587
SMTP_USER=                  # noreply@gammacash.online
SMTP_PASS=                  # Hostinger email password

# ── Google Analytics 4 ────────────────────────────────────────────────────────
GA4_MEASUREMENT_ID=         # G-XXXXXXXXXX — GA4 → Data Streams → Web → Measurement ID
GA4_API_SECRET=             # GA4 → Data Streams → Measurement Protocol API secrets → Create
GA4_PROPERTY_ID=            # GA4 → Admin → Property Settings → Property ID (numeric)
# Option A — local dev: path to downloaded service account JSON file
GA4_SERVICE_ACCOUNT_KEY_PATH=
# Option B — GitHub Actions: paste the full JSON as a single-line string
GA4_SERVICE_ACCOUNT_JSON=   # Google Cloud → IAM → Service Accounts → Keys → JSON

# ── YouTube ────────────────────────────────────────────────────────────────────
# Get CLIENT_ID + CLIENT_SECRET from console.cloud.google.com → APIs & Services → Credentials → Desktop OAuth
# Run scripts/youtube-auth.js once locally to obtain YOUTUBE_REFRESH_TOKEN
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# ── Pexels (stock video for video assembler) ──────────────────────────────────
PEXELS_API_KEY=             # pexels.com/api → free, instant approval

# ── ConvertKit (email list) ───────────────────────────────────────────────────
CONVERTKIT_API_KEY=         # app.convertkit.com → Settings → API → Secret API Key
                             # Run: npm run convertkit — creates form + WP widget + landing page

# ── Gumroad (digital products) ───────────────────────────────────────────────
GUMROAD_ACCESS_TOKEN=       # gumroad.com → Settings → Advanced → Application
                             # Run: npm run gumroad:paid — publishes AI Tools guide at $9.99

# ── Pinterest ─────────────────────────────────────────────────────────────────
# Apply at developers.pinterest.com for Standard Access (1–7 days approval)
# Then run: node scripts/pinterest-auth.js → follow browser OAuth flow
PINTEREST_APP_ID=
PINTEREST_APP_SECRET=
PINTEREST_REFRESH_TOKEN=    # Output from scripts/pinterest-auth.js
PINTEREST_BOARD_ID=         # Output from scripts/pinterest-auth.js

# ── Reddit (PERMANENTLY BLOCKED — skip) ──────────────────────────────────────
# Reddit blocked all new app registrations for automation use cases.
# REDDIT_CLIENT_ID=
# REDDIT_SECRET=
# REDDIT_USERNAME=
# REDDIT_PASSWORD=
