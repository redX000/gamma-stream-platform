ANTHROPIC_API_KEY=
WORDPRESS_URL=
WORDPRESS_USERNAME=
WORDPRESS_APP_PASSWORD=
CONVERTKIT_API_KEY=

# Google Analytics 4
GA4_PROPERTY_ID=
GA4_MEASUREMENT_ID=
# Option A — local file path to service account JSON key
GA4_SERVICE_ACCOUNT_KEY_PATH=
# Option B — inlined JSON string (use this for GitHub Actions secrets)
GA4_SERVICE_ACCOUNT_JSON=

# Reddit (snoowrap — script-app OAuth)
REDDIT_CLIENT_ID=
REDDIT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=
REDDIT_USER_AGENT=GammaStream/1.0 by [YOUR_REDDIT_USERNAME]

# Pinterest API v5
PINTEREST_ACCESS_TOKEN=
PINTEREST_BOARD_ID=

# YouTube Data API v3
# Get these from console.cloud.google.com → APIs & Services → Credentials (Desktop app OAuth)
# Run scripts/youtube-auth.js once locally to obtain YOUTUBE_REFRESH_TOKEN
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# Notifications & email (affiliate tracker + analytics reports)
NOTIFICATION_EMAIL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
